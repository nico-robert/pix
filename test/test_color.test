lappend auto_path [file dirname [file dirname [file dirname [info script]]]]

# source all.tcl
if {[catch {package present pix}]} {package require pix}

set color1 [pix::color::rgba 0 0 0 0.85]

if {$color1 ne "000000D8"} {
    error "color1 doesn't match with '000000D8'"
}

set color2 [pix::color::name "white"]
if {$color2 ne "FFFFFFFF"} {
    error "color2 doesn't match with 'FFFFFFFF'"
}

if {![pix::color::almostEqual "red" "red"]} {
    error "Color red should be equal to red"
}

set color3 [pix::color::mix "red" "white"]

if {$color3 ne "FF7F7FFF"} {
    error "color3 doesn't match with 'FF7F7FFF'"
}

set color4 [pix::color::hexHTML "#BADA55"]

if {![string match "BADA55FF" $color4]} {
    error "color4 doesn't match with 'BADA55FF'"
}

set color5 [pix::color::distance "red" "blue"]

if {$color5 < 52} {
    error "Distance color5 should be greater than 52."
}

exit 0